<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>User &amp; Membership · Balıklıova Seafood Cooperative</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root{
      --ink:#0a272f;--brine:#0e4f5e;--brine-700:#0b3d49;--foam:#eef4f3;--shell:#fff;
      --coral:#e35d3b;--coral-600:#c94e2f;--mist:#5f7d84;--line:#d8e3e2;
      --ok-bg:#e7f3ee;--ok-bd:#b6ddca;--ok-tx:#1d6b4c;--err-bg:#fdece8;--err-bd:#f3c2b6;--err-tx:#b23a1f;
      --radius:14px;--shadow:0 18px 50px -28px rgba(10,39,47,.55);
    }
    *{box-sizing:border-box;} html,body{margin:0;height:100%;}
    body{font-family:"Inter",system-ui,sans-serif;color:var(--ink);background:var(--foam);-webkit-font-smoothing:antialiased;}
    .hidden{display:none !important;}

    /* ===== AUTH VIEW ===== */
    .shell{min-height:100vh;display:grid;grid-template-columns:1.05fr 1fr;}
    .brand{position:relative;overflow:hidden;background:radial-gradient(120% 90% at 15% 10%,var(--brine) 0%,var(--brine-700) 55%,var(--ink) 100%);color:#eaf3f2;padding:clamp(28px,5vw,64px);display:flex;flex-direction:column;justify-content:space-between;}
    .eyebrow{font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:#8fc4c4;font-weight:600;}
    .brand h1{font-family:"Fraunces",serif;font-weight:600;font-size:clamp(30px,4vw,50px);line-height:1.05;margin:18px 0 0;letter-spacing:-.01em;}
    .brand .lede{margin-top:18px;max-width:30ch;color:#bcd6d6;font-size:16px;line-height:1.55;}
    .marks{display:flex;gap:34px;margin-top:30px;position:relative;z-index:1;}
    .mark .n{font-family:"Fraunces",serif;font-size:26px;font-weight:600;color:#fff;}
    .mark .l{font-size:12px;color:#8fc4c4;margin-top:2px;}
    .wave{position:absolute;left:0;right:0;bottom:-2px;width:100%;height:90px;opacity:.5;}
    .panel{display:flex;align-items:center;justify-content:center;padding:clamp(24px,4vw,56px);}
    .card{width:100%;max-width:440px;background:var(--shell);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:30px;}
    .tabs{display:flex;gap:4px;background:var(--foam);padding:4px;border-radius:11px;margin-bottom:24px;}
    .tab{flex:1;border:0;background:transparent;cursor:pointer;font:600 14px "Inter",sans-serif;color:var(--mist);padding:9px 10px;border-radius:8px;transition:all .15s;}
    .tab[aria-selected="true"]{background:var(--shell);color:var(--ink);box-shadow:0 1px 3px rgba(10,39,47,.12);}
    h2{font-family:"Fraunces",serif;font-weight:600;font-size:24px;margin:0 0 4px;}
    .sub{color:var(--mist);font-size:14px;margin:0 0 20px;}
    .seg{display:flex;border:1px solid var(--line);border-radius:10px;overflow:hidden;margin-bottom:20px;}
    .seg button{flex:1;border:0;background:var(--shell);cursor:pointer;font:600 13px "Inter",sans-serif;color:var(--mist);padding:10px 8px;transition:all .15s;}
    .seg button[aria-pressed="true"]{background:var(--brine);color:#fff;}
    label{display:block;font-size:13px;font-weight:500;margin:0 0 6px;}
    .field{margin-bottom:14px;}
    input{width:100%;padding:11px 13px;font:400 15px "Inter",sans-serif;color:var(--ink);background:var(--shell);border:1px solid var(--line);border-radius:10px;transition:border .15s,box-shadow .15s;}
    input:focus{outline:none;border-color:var(--brine);box-shadow:0 0 0 3px rgba(14,79,94,.14);}
    .btn{width:100%;border:0;cursor:pointer;border-radius:10px;font:600 15px "Inter",sans-serif;padding:12px;transition:background .15s,transform .05s;}
    .btn:active{transform:translateY(1px);}
    .btn-primary{background:var(--coral);color:#fff;} .btn-primary:hover{background:var(--coral-600);}
    .btn-ghost{background:var(--shell);color:var(--ink);border:1px solid var(--line);} .btn-ghost:hover{border-color:var(--brine);}
    .divider{display:flex;align-items:center;gap:12px;color:var(--mist);font-size:12px;margin:18px 0;}
    .divider::before,.divider::after{content:"";flex:1;height:1px;background:var(--line);}
    .social{display:grid;gap:9px;} .social .btn-ghost{display:flex;align-items:center;justify-content:center;gap:9px;font-size:14px;}
    .glyph{width:16px;height:16px;border-radius:50%;background:var(--brine);color:#fff;font-size:10px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;}
    .hint{text-align:center;font-size:12px;color:var(--mist);margin-top:10px;min-height:1em;}
    .note{font-size:12px;color:var(--mist);margin-top:14px;line-height:1.5;}
    .alert{border-radius:10px;padding:12px 14px;font-size:14px;margin-top:16px;}
    .alert.ok{background:var(--ok-bg);border:1px solid var(--ok-bd);color:var(--ok-tx);}
    .alert.err{background:var(--err-bg);border:1px solid var(--err-bd);color:var(--err-tx);}
    .receipt{margin-top:14px;border:1px dashed var(--brine);border-radius:10px;background:#f6fafa;padding:12px 14px;}
    .receipt .rh{display:flex;align-items:center;gap:8px;font-size:12px;font-weight:600;color:var(--brine);margin-bottom:8px;}
    .dot{width:8px;height:8px;border-radius:50%;background:var(--coral);animation:pulse 1.8s infinite;}
    @keyframes pulse{0%{box-shadow:0 0 0 0 rgba(227,93,59,.45);}70%{box-shadow:0 0 0 7px rgba(227,93,59,0);}100%{box-shadow:0 0 0 0 rgba(227,93,59,0);}}
    .receipt pre{margin:0;font:12px/1.5 ui-monospace,"SF Mono",Menlo,monospace;color:var(--ink);white-space:pre-wrap;word-break:break-word;}

    /* ===== DASHBOARD VIEW ===== */
    .dash{min-height:100vh;display:flex;flex-direction:column;}
    .dash-top{display:flex;align-items:center;justify-content:space-between;gap:16px;
      background:linear-gradient(100deg,var(--brine-700),var(--ink));color:#eaf3f2;
      padding:16px clamp(20px,4vw,48px);}
    .dash-top .b{font-family:"Fraunces",serif;font-weight:600;font-size:18px;}
    .dash-top .b span{display:block;font-family:"Inter";font-weight:500;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:#8fc4c4;}
    .dash-top .u{display:flex;align-items:center;gap:14px;font-size:14px;}
    .pill{display:inline-block;font-size:11px;font-weight:600;color:#cdeae6;background:rgba(255,255,255,.12);padding:3px 10px;border-radius:999px;}
    .link{background:none;border:0;color:#ffb8a3;font:600 13px "Inter",sans-serif;cursor:pointer;padding:0;}
    .dash-main{flex:1;padding:clamp(20px,4vw,40px);max-width:1100px;width:100%;margin:0 auto;}
    .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px;}
    .stat{background:var(--shell);border:1px solid var(--line);border-radius:12px;padding:18px 20px;}
    .stat .n{font-family:"Fraunces",serif;font-size:30px;font-weight:600;line-height:1;color:var(--ink);}
    .stat .l{font-size:12px;color:var(--mist);margin-top:8px;letter-spacing:.02em;}
    .pcard{background:var(--shell);border:1px solid var(--line);border-radius:14px;box-shadow:var(--shadow);overflow:hidden;}
    .pcard .ph{display:flex;gap:6px;padding:12px 16px;border-bottom:1px solid var(--line);}
    .dtab{border:0;background:transparent;cursor:pointer;font:600 14px "Inter",sans-serif;color:var(--mist);padding:8px 14px;border-radius:8px;transition:all .15s;}
    .dtab[aria-selected="true"]{background:var(--foam);color:var(--ink);}
    .pbody{padding:8px 8px 16px;}
    .table{width:100%;border-collapse:collapse;font-size:14px;}
    .table th{text-align:left;color:var(--mist);font-weight:600;padding:12px 16px;border-bottom:1px solid var(--line);font-size:12px;letter-spacing:.04em;text-transform:uppercase;}
    .table td{padding:13px 16px;border-bottom:1px solid var(--foam);}
    .table tr:last-child td{border-bottom:0;}
    .table tbody tr:hover{background:#f8fbfb;}
    .mono{font:12px ui-monospace,Menlo,monospace;color:var(--brine);}
    .empty{padding:28px 16px;text-align:center;color:var(--mist);font-size:14px;}
    .welcome{padding:8px 8px 4px;}
    .welcome h3{font-family:"Fraunces",serif;font-weight:600;font-size:20px;margin:0 0 6px;}

    @media (max-width:820px){
      .shell{grid-template-columns:1fr;}.brand{min-height:230px;}.wave{display:none;}
      .stats{grid-template-columns:repeat(2,1fr);}
    }
    @media (prefers-reduced-motion:reduce){.dot{animation:none;}}
  </style>
</head>
<body>
  <!-- ================= AUTH VIEW ================= -->
  <div id="auth-view" class="shell">
    <aside class="brand">
      <div>
        <div class="eyebrow">Balıklıova · Aegean Coast</div>
        <h1>Balıklıova Seafood Cooperative</h1>
        <p class="lede">Register your boat or your business to join the daily online fish auction.</p>
      </div>
      <div class="marks">
        <div class="mark"><div class="n"><%= stats.members %></div><div class="l">registered boats</div></div>
        <div class="mark"><div class="n"><%= stats.buyers %></div><div class="l">registered buyers</div></div>
      </div>
      <svg class="wave" viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M0,64 C180,110 360,20 540,52 C720,84 900,120 1080,86 C1260,52 1380,70 1440,78 L1440,120 L0,120 Z" fill="#0a272f" opacity="0.55"/>
        <path d="M0,86 C200,40 420,116 640,92 C860,68 1060,30 1280,66 C1360,79 1410,82 1440,84 L1440,120 L0,120 Z" fill="#082026" opacity="0.7"/>
      </svg>
    </aside>

    <main class="panel">
      <div class="card">
        <% if (error) { %><div class="alert err" style="margin-top:0;margin-bottom:16px"><%= error %></div><% } %>
        <div class="tabs" role="tablist" id="tabs">
          <button class="tab" role="tab" aria-selected="true" data-view="signup">Sign up</button>
          <button class="tab" role="tab" aria-selected="false" data-view="signin">Sign in</button>
        </div>

        <section id="view-signup">
          <h2>Create an account</h2>
          <p class="sub">Join the cooperative's online auction.</p>
          <div class="seg" id="signup-role">
            <button data-role="member" aria-pressed="true">Cooperative member</button>
            <button data-role="buyer" aria-pressed="false">Buyer</button>
          </div>
          <div id="su-member">
            <div class="field"><label>Full name</label><input id="su-m-name" placeholder="e.g. İrem Gülser" /></div>
            <div class="field"><label>Boat name</label><input id="su-m-boat" placeholder="e.g. Mavi Deniz" /></div>
          </div>
          <div id="su-buyer" class="hidden">
            <div class="field"><label>Name / business</label><input id="su-b-name" placeholder="e.g. Deniz Restaurant" /></div>
            <div class="field"><label>Address (neighborhood, street, building / apt no)</label><input id="su-b-line" placeholder="e.g. Kordon Mah. Atatürk Cad. No:12/3" /></div>
            <div class="field" style="display:flex;gap:10px;margin-bottom:0">
              <div class="field" style="flex:1"><label>District</label><input id="su-b-district" placeholder="e.g. Urla" /></div>
              <div class="field" style="flex:1"><label>City</label><input id="su-b-city" placeholder="e.g. İzmir" /></div>
            </div>
            <div class="field"><label>Postal code (optional)</label><input id="su-b-postal" placeholder="e.g. 35430" /></div>
          </div>
          <div class="field"><label>Email</label><input id="su-email" type="email" placeholder="you@example.com" /></div>
          <div class="field"><label>Phone</label><input id="su-phone" placeholder="05xx xxx xx xx" /></div>
          <div class="field"><label>Password</label><input id="su-password" type="password" placeholder="Choose a password" /></div>
          <button class="btn btn-primary" id="su-submit">Create account</button>
          <div class="divider">or</div>
          <div class="social">
            <button class="btn btn-ghost" data-social="Google"><span class="glyph">G</span> Continue with Google</button>
            <button class="btn btn-ghost" data-social="Apple"><span class="glyph"></span> Continue with Apple</button>
          </div>
          <p class="hint"></p>
          <div id="su-result"></div>
          <p class="note">Buyers: your address and phone are included in the registration event so the cooperative can arrange courier delivery of your fish. Members: contact details stay within this service.</p>
        </section>

        <section id="view-signin" class="hidden">
          <h2>Welcome back</h2>
          <p class="sub">Sign in to your account.</p>
          <div class="seg" id="signin-role">
            <button data-role="member" aria-pressed="true">Cooperative member</button>
            <button data-role="buyer" aria-pressed="false">Buyer</button>
          </div>
          <div class="field"><label>Email</label><input id="si-email" type="email" placeholder="you@example.com" /></div>
          <div class="field"><label>Password</label><input id="si-password" type="password" placeholder="Your password" /></div>
          <button class="btn btn-primary" id="si-submit">Sign in</button>
          <div class="divider">or</div>
          <div class="social">
            <button class="btn btn-ghost" data-social="Google"><span class="glyph">G</span> Continue with Google</button>
            <button class="btn btn-ghost" data-social="Apple"><span class="glyph"></span> Continue with Apple</button>
          </div>
          <p class="hint"></p>
          <div id="si-result"></div>
        </section>
      </div>
    </main>
  </div>

  <!-- ================= DASHBOARD VIEW ================= -->
  <div id="dashboard-view" class="dash hidden">
    <header class="dash-top">
      <div class="b">Balıklıova Seafood Cooperative<span>User &amp; Membership</span></div>
      <div class="u">
        <span id="dash-name">—</span>
        <span class="pill" id="dash-role">—</span>
        <button class="link" id="signout">Sign out</button>
      </div>
    </header>
    <main class="dash-main">
      <section class="stats">
        <div class="stat"><div class="n" id="st-boats">–</div><div class="l">Registered boats</div></div>
        <div class="stat"><div class="n" id="st-buyers">–</div><div class="l">Registered buyers</div></div>
        <div class="stat"><div class="n mono" id="st-id" style="font-size:20px">–</div><div class="l">Your ID</div></div>
        <div class="stat"><div class="n" id="st-type" style="font-size:20px">–</div><div class="l">Account type</div></div>
      </section>
      <section class="pcard" id="dash-content"></section>
    </main>
  </div>

  <script src="/main.js"></script>
</body>
</html>
