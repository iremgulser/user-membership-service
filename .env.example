# Copy to ".env" and adjust. Never commit your real .env.
PORT=3001
JWT_SECRET=change-me-to-something-long-and-random
JWT_EXPIRES_IN=12h

# --- PostgreSQL ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=user_membership_service
PGUSER=postgres
PGPASSWORD=postgres
# Or a single URL (e.g. from a hosted provider):
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# PGSSLMODE=require        # enable TLS for hosted databases

# --- Kafka (Confluent Cloud, from the Queue team) ---
# KAFKA_BROKERS=pkc-xxxxx.<region>.confluent.cloud:9092
# KAFKA_CLIENT_ID=user-membership-service
# KAFKA_SASL_USERNAME=<API_KEY>
# KAFKA_SASL_PASSWORD=<API_SECRET>
